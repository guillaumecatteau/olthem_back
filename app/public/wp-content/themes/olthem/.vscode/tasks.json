{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "SCSS Watch",
      "type": "shell",
      "command": "npm.cmd",
      "args": ["run", "scss:watch"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": {
        "owner": "scss",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Sass is watching for changes",
          "endsPattern": "^$"
        }
      },
      "presentation": {
        "reveal": "never",
        "panel": "dedicated",
        "clear": false
      }
    }
  ]
}
